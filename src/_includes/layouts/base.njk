<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
    <meta name="description" content="{{ description or summary or site.description }}">
    <link rel="icon" href="{{ '/favicon.svg' | relativeUrl(page.url) }}" type="image/svg+xml">
    {% set stylesheetUrl = "/assets/css/style.css?v=" ~ assetVersion %}
    <link rel="stylesheet" href="{{ stylesheetUrl | relativeUrl(page.url) }}">
  </head>
  {% set currentUrl = page.url or "/" %}
  <body class="{% if currentUrl == '/' %}home{% else %}page{% endif %}">
    <a class="skip-link" href="#contenuto">Salta al contenuto</a>

    <header class="site-header">
      <div class="container header-inner">
        <a class="site-title" href="{{ '/' | relativeUrl(page.url) }}" aria-label="{{ site.name }} - Home">
          <span class="brand-mark" aria-hidden="true"><span></span></span>
          <span>{{ site.name }}</span>
        </a>
        <nav class="site-nav" aria-label="Navigazione principale">
          <a href="{{ '/' | relativeUrl(page.url) }}"{% if currentUrl == "/" %} aria-current="page"{% endif %}>Home</a>
          <a href="{{ '/storia/' | relativeUrl(page.url) }}"{% if currentUrl == "/storia/" %} aria-current="page"{% endif %}>Storia</a>
          <a href="{{ '/avvisi/' | relativeUrl(page.url) }}"{% if currentUrl.indexOf("/avvisi/") == 0 %} aria-current="page"{% endif %}>Avvisi</a>
          <a href="{{ '/documenti/' | relativeUrl(page.url) }}"{% if currentUrl == "/documenti/" %} aria-current="page"{% endif %}>Documenti pubblici</a>
          <a href="{{ '/area-riservata/' | relativeUrl(page.url) }}"{% if currentUrl == "/area-riservata/" %} aria-current="page"{% endif %}>Area riservata</a>
        </nav>
      </div>
    </header>

    <main id="contenuto" class="container main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>&copy; {{ currentYear }} {{ site.name }}.</p>
        <p>
          <a href="{{ '/privacy/' | relativeUrl(page.url) }}">Privacy</a>
          {% if site.email %}<span aria-hidden="true"> &middot; </span><a href="mailto:{{ site.email }}">Contatti</a>{% endif %}
        </p>
      </div>
    </footer>
  </body>
</html>
